<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Game Copier - HaychTools</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
  <style>
    body {
      margin:0;
      padding:0;
      background:#05060a;
      color:white;
      font-family:'Poppins',sans-serif;
      min-height:100vh;
      display:flex;
      flex-direction:column;
      align-items:center;
      padding:40px 20px;
    }
    h1 {
      font-family:'Rubik Puddles',cursive;
      font-size:60px;
      background:linear-gradient(90deg,#ff2e63,#ff6b6b);
      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;
      margin-bottom:50px;
      text-shadow:0 0 20px #ff2e63;
    }
    .input-box {
      width:100%;
      max-width:700px;
      margin-bottom:60px;
    }
    .input-box input[type="file"] {
      width:100%;
      padding:18px;
      font-size:18px;
      background:rgba(255,255,255,0.08);
      border:2px solid #ff2e63;
      border-radius:12px;
      color:white;
      cursor:pointer;
    }
    .input-box input[type="file"]::file-selector-button {
      padding:12px 24px;
      background:#ff2e63;
      border:none;
      border-radius:8px;
      color:white;
      font-weight:bold;
      cursor:pointer;
      margin-right:12px;
    }
    .tutorial {
      width:100%;
      max-width:560px;
      background:rgba(0,0,0,0.4);
      padding:20px;
      border-radius:16px;
      box-shadow:0 0 30px rgba(255,46,99,0.3);
      text-align:center;
    }
    .tutorial h2 {
      margin-bottom:20px;
      font-size:28px;
      color:#ff6b6b;
    }
    iframe {
      width:100%;
      aspect-ratio:16/9;
      border:none;
      border-radius:12px;
      box-shadow:0 0 20px rgba(0,0,0,0.6);
    }
    .back {
      margin-top:60px;
      padding:14px 32px;
      font-size:18px;
      background:linear-gradient(135deg,#00f0ff,#00ff9d);
      border:none;
      border-radius:12px;
      color:#000;
      font-weight:bold;
      cursor:pointer;
    }
  </style>
</head>
<body>

  <h1>Game Copier</h1>

  <div class="input-box">
    <input type="file" id="gameFile" accept=".rbxl,.rbxlx" />
    <!-- accept whatever file types you actually need for the copier -->
  </div>

  <div class="tutorial">
    <h2>Tutorial</h2>
    <iframe 
      src="https://www.youtube.com/embed/dQw4w9WgXcQ" 
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
      allowfullscreen>
    </iframe>
    <!-- ^^^ Replace this src with your REAL tutorial video embed link from YouTube (get it from Share → Embed) -->
  </div>

  <button class="back" onclick="location.href='../'">Back to Hub</button>

</body>
</html>
